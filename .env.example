# Control Plane — environment variables
# Copy to .env and fill in values

# Required
API_TOKEN=your-api-token
ENCRYPTION_KEY=your-64-char-hex-key
JWT_SECRET=your-64-char-hex-key
POSTGRES_PASSWORD=your-db-password

# First-time WebAuthn setup (set a random secret, use in X-Setup-Token header, then remove)
SETUP_TOKEN=

# Registration gate (if set, POST /auth/register requires X-Registration-Token header)
REGISTRATION_TOKEN=

# Server binding (default: 127.0.0.1, set to 10.10.0.1 for WireGuard)
BIND_ADDR=127.0.0.1
HOST_PORT=8085

# Optional
CORS_ORIGINS=http://localhost:5173
WEBAUTHN_RPID=localhost
WEBAUTHN_ORIGIN=http://localhost:8085

# WireGuard mesh (optional)
WG_HUB_PUBLIC_KEY=
WG_HUB_ENDPOINT=
WG_NETWORK_CIDR=10.10.0.0/24

# Caddy dynamic routing (optional)
CADDY_ADMIN_URL=
CADDY_SERVER_NAME=srv1
CADDY_DOMAIN=example.com
